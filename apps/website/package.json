{
  "name": "@cocso-ui/website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "update": "pnpm update",
    "dev": "next dev --hostname 0.0.0.0 --port 6005",
    "prebuild": "node -e \"import('./node_modules/fumadocs-mdx/dist/next/index.js').then(m => m.postInstall({ configPath: 'source.config.ts', outDir: '.source' })).catch(e => { console.error(e); process.exit(1); })\"",
    "build": "next build",
    "start": "next start",
    "check-types": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --fix"
  },
  "dependencies": {
    "@cocso-ui/css": "workspace:^",
    "@cocso-ui/mcp": "workspace:^",
    "@cocso-ui/react": "workspace:^",
    "@cocso-ui/react-icons": "workspace:^",
    "@modelcontextprotocol/sdk": "1.26.0",
    "@suspensive/react": "^3.20.2",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "^16.7.10",
    "fumadocs-mdx": "^14.2.11",
    "fumadocs-ui": "^16.7.10",
    "mcp-handler": "^1.1.0",
    "next": "^16.2.2",
    "posthog-js": "^1.364.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
