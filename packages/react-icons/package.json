{
  "name": "@cocso-ui/react-icons",
  "version": "0.1.6",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cocso/cocso-ui.git",
    "directory": "packages/react-icons"
  },
  "scripts": {
    "prebuild": "rm -rf dist && node scripts/generate-index-file.mjs",
    "build": "rollup -c rollup.config.cjs",
    "check-types": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --fix"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@babel/preset-react": "catalog:build",
    "@babel/preset-typescript": "catalog:build",
    "@rollup/plugin-babel": "catalog:build",
    "@rollup/plugin-commonjs": "catalog:build",
    "@rollup/plugin-node-resolve": "catalog:build",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "react": "catalog:core",
    "rollup": "catalog:build",
    "rollup-plugin-dts": "catalog:build",
    "rollup-plugin-postcss": "catalog:build",
    "typescript": "catalog:core"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
