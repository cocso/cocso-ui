{
  "name": "@cocso-ui/figma",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "generate": "tsx scripts/generate-tokens.ts",
    "generate:figma-json": "tsx scripts/generate-figma-json.ts",
    "extract": "tsx scripts/extract-components.ts",
    "golden-matrix": "pnpm generate && tsx scripts/golden-matrix.ts",
    "prebuild": "pnpm generate",
    "build": "node build.js",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "check-types": "tsc --noEmit",
    "pretest": "pnpm generate",
    "test": "vitest run",
    "pretest:coverage": "pnpm generate",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cocso-ui/baseframe-sources": "workspace:*",
    "@cocso-ui/icons": "workspace:*",
    "@cocso-ui/recipe": "workspace:*",
