{
  "name": "@cocso-ui/recipe",
  "version": "0.0.1",
  "description": "Component visual spec recipes — CI-enforced declarative mirror for React and Figma",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cocso/cocso-ui.git",
    "directory": "packages/recipe"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./resolvers/react": {
      "types": "./dist/resolvers/react.d.ts",
      "import": "./src/resolvers/react.ts"
    },
    "./recipes/*": {
      "types": "./dist/recipes/*.d.ts",
      "import": "./src/recipes/*.ts"
    },
    "./utils": {
      "types": "./dist/utils/token-classification.d.ts",
      "import": "./src/utils/token-classification.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
