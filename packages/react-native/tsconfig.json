{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "rootDir": "./src",
    "allowImportingTsExtensions": false,
    "skipLibCheck": true,
    "types": ["react", "react-native"]
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
