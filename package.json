{
  "name": "cocso-ui",
  "private": true,
  "scripts": {
    "check": "turbo run lint",
    "build": "turbo run build",
    "build:storybook": "turbo run build:storybook --filter=@cocso-ui/storybook",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/cli": "^2.30.0",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "ultracite": "^7.2.5"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.31.0"
}
