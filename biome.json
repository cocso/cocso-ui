{
  "$schema": "node_modules/@biomejs/biome/configuration_schema.json",
  "root": true,
  "extends": ["ultracite/core", "ultracite/react"],

  "files": {
    "includes": ["!!**/pnpm-lock.yaml", "!!**/bin", "!!**/dist"]
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "arrowParentheses": "asNeeded"
    }
  },

  "css": {
    "parser": {
      "cssModules": true
    }
  },

  "linter": {
    "rules": {
      "style": {
        "useFilenamingConvention": "off",
        "useConsistentTypeDefinitions": "off",
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "useStrictMode": "off"
      }
    }
  },

  "overrides": [
    {
      "includes": ["**/index.ts", "**/index.tsx"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off",
            "noReExportAll": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.stories.{ts,tsx}"],
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": ["**/*.{test,spec}.{ts,tsx}", "**/__tests__/**/*"],
      "linter": {
        "rules": {
          "suspicious": {
            "noEmptyBlockStatements": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          },
          "a11y": {
            "useButtonType": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.module.css"],
      "linter": {
        "rules": {
          "style": {
            "noDescendingSpecificity": "off"
          }
        }
      }
    },
    {
      "includes": ["**/rollup.config.cjs", "**/build.js", "**/scripts/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "style": {
            "noProcessEnv": "off"
          }
        }
      }
    }
  ]
}
