:root {
  --cocso-color-white: #ffffff;
  --cocso-color-white-alpha-5: rgba(255, 255, 255, 0.05);
  --cocso-color-white-alpha-10: rgba(255, 255, 255, 0.1);
  --cocso-color-white-alpha-20: rgba(255, 255, 255, 0.2);
  --cocso-color-white-alpha-30: rgba(255, 255, 255, 0.3);
  --cocso-color-white-alpha-40: rgba(255, 255, 255, 0.4);
  --cocso-color-white-alpha-50: rgba(255, 255, 255, 0.5);
  --cocso-color-white-alpha-60: rgba(255, 255, 255, 0.6);
  --cocso-color-white-alpha-70: rgba(255, 255, 255, 0.7);
  --cocso-color-white-alpha-80: rgba(255, 255, 255, 0.8);
  --cocso-color-white-alpha-90: rgba(255, 255, 255, 0.9);
  --cocso-color-black: #000000;
  --cocso-color-black-alpha-5: rgba(0, 0, 0, 0.05);
  --cocso-color-black-alpha-10: rgba(0, 0, 0, 0.1);
  --cocso-color-black-alpha-20: rgba(0, 0, 0, 0.2);
  --cocso-color-black-alpha-30: rgba(0, 0, 0, 0.3);
  --cocso-color-black-alpha-40: rgba(0, 0, 0, 0.4);
  --cocso-color-black-alpha-50: rgba(0, 0, 0, 0.5);
  --cocso-color-black-alpha-60: rgba(0, 0, 0, 0.6);
  --cocso-color-black-alpha-70: rgba(0, 0, 0, 0.7);
  --cocso-color-black-alpha-80: rgba(0, 0, 0, 0.8);
  --cocso-color-black-alpha-90: rgba(0, 0, 0, 0.9);
  --cocso-color-neutral-50: #f4f5f6;
  --cocso-color-neutral-100: #e6e8ea;
  --cocso-color-neutral-200: #cdd1d5;
  --cocso-color-neutral-300: #b1b8be;
  --cocso-color-neutral-400: #8a949e;
  --cocso-color-neutral-500: #6d7882;
  --cocso-color-neutral-600: #58616a;
  --cocso-color-neutral-700: #464c53;
  --cocso-color-neutral-800: #33363d;
  --cocso-color-neutral-900: #1e2124;
  --cocso-color-neutral-950: #131416;
  --cocso-color-primary-50: var(--cocso-color-neutral-50);
  --cocso-color-primary-100: var(--cocso-color-neutral-100);
  --cocso-color-primary-200: var(--cocso-color-neutral-200);
  --cocso-color-primary-300: var(--cocso-color-neutral-300);
  --cocso-color-primary-400: var(--cocso-color-neutral-400);
  --cocso-color-primary-500: var(--cocso-color-neutral-500);
  --cocso-color-primary-600: var(--cocso-color-neutral-600);
  --cocso-color-primary-700: var(--cocso-color-neutral-700);
  --cocso-color-primary-800: var(--cocso-color-neutral-800);
  --cocso-color-primary-900: var(--cocso-color-neutral-900);
  --cocso-color-primary-950: var(--cocso-color-neutral-950);
  --cocso-color-info-50: #ecf2fe;
  --cocso-color-info-100: #d8e5fd;
  --cocso-color-info-200: #b1cefb;
  --cocso-color-info-300: #86aff9;
  --cocso-color-info-400: #4c87f6;
  --cocso-color-info-500: #256ef4;
  --cocso-color-info-600: #0b50d0;
  --cocso-color-info-700: #083891;
  --cocso-color-info-800: #052561;
  --cocso-color-info-900: #03163a;
  --cocso-color-info-950: #020f27;
  --cocso-color-danger-50: #fdefec;
  --cocso-color-danger-100: #fcdfd9;
  --cocso-color-danger-200: #f7afa1;
  --cocso-color-danger-300: #f48771;
  --cocso-color-danger-400: #f05f42;
  --cocso-color-danger-500: #de3412;
  --cocso-color-danger-600: #bd2c0f;
  --cocso-color-danger-700: #8a240f;
  --cocso-color-danger-800: #5c180a;
  --cocso-color-danger-900: #390d05;
  --cocso-color-danger-950: #260903;
  --cocso-color-warning-50: #fff3db;
  --cocso-color-warning-100: #ffe0a3;
  --cocso-color-warning-200: #ffc95c;
  --cocso-color-warning-300: #ffb114;
  --cocso-color-warning-400: #c78500;
  --cocso-color-warning-500: #9e6a00;
  --cocso-color-warning-600: #8a5c00;
  --cocso-color-warning-700: #614100;
  --cocso-color-warning-800: #422c00;
  --cocso-color-warning-900: #2e1f00;
  --cocso-color-warning-950: #241800;
  --cocso-color-success-50: #eaf6ec;
  --cocso-color-success-100: #d8eedd;
  --cocso-color-success-200: #a9dab4;
  --cocso-color-success-300: #7ec88e;
  --cocso-color-success-400: #3fa654;
  --cocso-color-success-500: #228738;
  --cocso-color-success-600: #267337;
  --cocso-color-success-700: #285d33;
  --cocso-color-success-800: #1f4727;
  --cocso-color-success-900: #122b18;
  --cocso-color-success-950: #0e2012;
  --cocso-text-xs: 12px;
  --cocso-text-sm: 14px;
  --cocso-text-base: 16px;
  --cocso-font-weight-thin: 100;
  --cocso-font-weight-extralight: 200;
  --cocso-font-weight-light: 300;
  --cocso-font-weight-regular: 400;
  --cocso-font-weight-medium: 500;
  --cocso-font-weight-semibold: 600;
  --cocso-font-weight-bold: 700;
  --cocso-font-weight-extrabold: 800;
  --cocso-font-weight-black: 900;
  --cocso-radius-1: 2px;
  --cocso-radius-2: 4px;
  --cocso-radius-3: 6px;
  --cocso-radius-4: 8px;
  --cocso-radius-5: 12px;
  --cocso-radius-6: 16px;
  --cocso-radius-full: 1000px;
  --cocso-shadow-y-3: 8px;
  --cocso-shadow-y-4: 16px;
  --cocso-shadow-blur-3: 16px;
  --cocso-shadow-blur-4: 24px;
  --cocso-shadow-xs: 0px 1px 2px 0px var(--cocso-color-alpha-shadow1), 0px 0px 2px 0px var(--cocso-color-alpha-shadow1);
  --cocso-shadow-sm: 0px 0px 2px 0px var(--cocso-color-alpha-shadow1), 0px 4px 8px 0px var(--cocso-color-alpha-shadow2);
  --cocso-shadow-md: 0px 0px 2px 0px var(--cocso-color-alpha-shadow2), 0px var(--cocso-shadow-y-3) var(--cocso-shadow-blur-3) 0px var(--cocso-color-alpha-shadow3);
  --cocso-shadow-lg: 0px 0px 2px 0px var(--cocso-color-alpha-shadow2), 0px var(--cocso-shadow-y-4) var(--cocso-shadow-blur-4) 0px var(--cocso-color-alpha-shadow3);
  --cocso-spacing-0: 0px;
  --cocso-spacing-1: 1px;
  --cocso-spacing-2: 2px;
  --cocso-spacing-3: 4px;
  --cocso-spacing-4: 6px;
  --cocso-spacing-5: 8px;
  --cocso-spacing-6: 10px;
  --cocso-spacing-7: 12px;
  --cocso-spacing-8: 16px;
  --cocso-spacing-9: 20px;
  --cocso-spacing-10: 24px;
  --cocso-spacing-11: 28px;
  --cocso-spacing-12: 32px;
  --cocso-spacing-13: 36px;
  --cocso-spacing-14: 40px;
  --cocso-spacing-15: 44px;
  --cocso-spacing-16: 48px;
  --cocso-spacing-17: 56px;
  --cocso-spacing-18: 64px;
  --cocso-spacing-19: 72px;
  --cocso-spacing-20: 80px;
  --cocso-spacing-21: 96px;
  --cocso-spacing-max: 1000px;
  --cocso-z-index-behind: -1;
  --cocso-z-index-base: 0;
  --cocso-z-index-above: 1;
  --cocso-z-index-header: 50;
  --cocso-z-index-overlay: 100;
  --cocso-z-index-dialog: 200;
  --cocso-z-index-dialog-content: 250;
  --cocso-color-alpha-shadow1: rgba(0, 0, 0, 0.04);
  --cocso-color-alpha-shadow2: rgba(0, 0, 0, 0.08);
  --cocso-color-alpha-shadow3: rgba(0, 0, 0, 0.12);
  --cocso-color-transparent: transparent;
  --cocso-color-text-primary: var(--cocso-color-neutral-950);
  --cocso-color-text-secondary: var(--cocso-color-neutral-600);
  --cocso-color-text-tertiary: var(--cocso-color-neutral-400);
  --cocso-color-text-disabled: var(--cocso-color-neutral-400);
  --cocso-color-text-on-primary: var(--cocso-color-white);
  --cocso-color-text-muted: var(--cocso-color-neutral-500);
  --cocso-color-surface-primary: var(--cocso-color-white);
  --cocso-color-surface-secondary: var(--cocso-color-neutral-50);
  --cocso-color-surface-inverse: var(--cocso-color-neutral-950);
  --cocso-color-surface-neutral: var(--cocso-color-neutral-100);
  --cocso-color-border-primary: var(--cocso-color-neutral-200);
  --cocso-color-border-secondary: var(--cocso-color-neutral-100);
  --cocso-color-interactive-primary: var(--cocso-color-primary-950);
  --cocso-color-interactive-primary-hover: var(--cocso-color-primary-800);
  --cocso-color-interactive-primary-active: var(--cocso-color-primary-700);
  --cocso-color-interactive-primary-muted: var(--cocso-color-primary-500);
  --cocso-color-interactive-secondary: var(--cocso-color-neutral-100);
  --cocso-color-interactive-secondary-hover: var(--cocso-color-neutral-200);
  --cocso-color-interactive-danger: var(--cocso-color-danger-500);
  --cocso-color-interactive-danger-hover: var(--cocso-color-danger-600);
  --cocso-color-interactive-danger-active: var(--cocso-color-danger-700);
  --cocso-color-interactive-danger-hover-subtle: var(--cocso-color-danger-400);
  --cocso-color-interactive-success: var(--cocso-color-success-500);
  --cocso-color-interactive-success-hover: var(--cocso-color-success-600);
  --cocso-color-interactive-success-active: var(--cocso-color-success-700);
  --cocso-color-interactive-success-hover-subtle: var(--cocso-color-success-400);
  --cocso-color-interactive-warning: var(--cocso-color-warning-300);
  --cocso-color-interactive-warning-hover: var(--cocso-color-warning-400);
  --cocso-color-interactive-warning-active: var(--cocso-color-warning-500);
  --cocso-color-interactive-warning-hover-subtle: var(--cocso-color-warning-400);
  --cocso-color-interactive-info: var(--cocso-color-info-500);
  --cocso-color-interactive-info-hover: var(--cocso-color-info-600);
  --cocso-color-interactive-info-active: var(--cocso-color-info-700);
  --cocso-color-interactive-info-hover-subtle: var(--cocso-color-info-400);
  --cocso-color-focus-ring: var(--cocso-color-primary-950);
  --cocso-color-feedback-danger: var(--cocso-color-danger-500);
  --cocso-color-feedback-danger-subtle: var(--cocso-color-danger-50);
  --cocso-color-feedback-danger-text: var(--cocso-color-danger-600);
  --cocso-color-feedback-danger-border: var(--cocso-color-danger-200);
  --cocso-color-feedback-success: var(--cocso-color-success-500);
  --cocso-color-feedback-success-subtle: var(--cocso-color-success-50);
  --cocso-color-feedback-success-text: var(--cocso-color-success-600);
  --cocso-color-feedback-success-border: var(--cocso-color-success-200);
  --cocso-color-feedback-success-muted: var(--cocso-color-success-400);
  --cocso-color-feedback-warning: var(--cocso-color-warning-500);
  --cocso-color-feedback-warning-subtle: var(--cocso-color-warning-50);
  --cocso-color-feedback-warning-text: var(--cocso-color-warning-600);
  --cocso-color-feedback-warning-border: var(--cocso-color-warning-200);
  --cocso-color-feedback-info: var(--cocso-color-info-500);
  --cocso-color-feedback-info-subtle: var(--cocso-color-info-50);
  --cocso-color-feedback-info-text: var(--cocso-color-info-600);
  --cocso-color-feedback-info-border: var(--cocso-color-info-200);
  --cocso-duration-fast: 0.15s;
  --cocso-duration-normal: 0.2s;
  --cocso-duration-slow: 0.25s;
  --cocso-duration-decorative: 0.75s;
  --cocso-duration-decorative-slow: 1.5s;
  --cocso-easing-default: ease-in-out;
  --cocso-easing-soft: ease;
  --cocso-easing-entrance: cubic-bezier(0.16, 1, 0.3, 1);
  --cocso-easing-accordion: cubic-bezier(0.87, 0, 0.13, 1);
  --cocso-shadow-thumb: var(--cocso-shadow-xs);
  --cocso-shadow-card: var(--cocso-shadow-sm);
  --cocso-shadow-dropdown: var(--cocso-shadow-sm);
  --cocso-shadow-popover: var(--cocso-shadow-sm);
  --cocso-shadow-dialog: var(--cocso-shadow-md);
}
