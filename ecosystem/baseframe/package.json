{
  "name": "@cocso-ui/baseframe",
  "version": "0.0.6",
  "description": "A CLI tool for managing and generating baseframe",
  "main": "bin/index.js",
  "module": "bin/index.js",
  "type": "module",
  "private": false,
  "bin": {
    "baseframe": "bin/index.js"
  },
  "scripts": {
    "build": "node build.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --fix",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cocso-ui/baseframe-sources": "workspace:*",
    "fs-extra": "^11.3.4",
    "yaml": "^2.8.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
